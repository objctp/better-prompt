{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@opentui/solid",
    "types": ["node"],
    "outDir": "dist",
    "noEmit": true,
    "isolatedModules": true,
    "resolveJsonModule": true
  },
  "include": ["plugins/**/*.ts", "plugins/**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}