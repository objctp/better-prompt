{
  "description": "Intercepts and enhances user prompts before submission to Claude",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'mkdir -p ~/.claude \"$CLAUDE_PROJECT_DIR/.claude/better-prompt\" && [ ! -f ~/.claude/better-prompt.local.md ] && cp \"${CLAUDE_PLUGIN_ROOT}/config/better-prompt.local.md.example\" ~/.claude/better-prompt.local.md 2>/dev/null || true; pid_file=\"$CLAUDE_PROJECT_DIR/.claude/better-prompt/.stop-pid\"; if [ -f \"$pid_file\" ]; then pid=$(cat \"$pid_file\" 2>/dev/null); if [ -n \"$pid\" ] && kill -0 \"$pid\" 2>/dev/null; then kill \"$pid\" 2>/dev/null; fi; rm -f \"$pid_file\"; fi'",
            "statusMessage": "Initialising better-prompt",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/enhance.sh",
            "statusMessage": "Correcting and Enhancing Prompt...",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptExpansion": [
      {
        "matcher": "better-prompt:toggle",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/toggle.sh",
            "statusMessage": "Toggling better-prompt setting...",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "better-prompt:config",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/config-hook.sh",
            "statusMessage": "Setting better-prompt config...",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "better-prompt:audit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/audit.sh",
            "statusMessage": "Reading audit trail...",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'rm -f \"$CLAUDE_PROJECT_DIR/.claude/better-prompt/.sentinel\" \"$CLAUDE_PROJECT_DIR/.claude/better-prompt/.stop-pid\" \"$CLAUDE_PROJECT_DIR/.claude/better-prompt/.enhance-session\" \"$CLAUDE_PROJECT_DIR/.claude/better-prompt/.context\"'",
            "statusMessage": "Cleaning up...",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
