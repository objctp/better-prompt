{
  "description": "Intercepts and enhances user prompts before submission to Claude",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'mkdir -p ~/.claude && [ ! -f ~/.claude/better-prompt.local.md ] && cp \"${CLAUDE_PLUGIN_ROOT}/examples/better-prompt.local.md.example\" ~/.claude/better-prompt.local.md 2>/dev/null || true; mkdir -p \"$CLAUDE_PROJECT_DIR/.claude\" && touch \"$CLAUDE_PROJECT_DIR/.claude/prompts.json\"'",
            "statusMessage": "Placing config file and .prompts.json on project root",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/enhance.sh",
            "statusMessage": "Correcting and Enhancing Prompt...",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'rm -f \"$CLAUDE_PROJECT_DIR/.claude/prompts.json\" \"$CLAUDE_PROJECT_DIR/.claude/.better-prompt-enhance-session\" \"$CLAUDE_PROJECT_DIR/.claude/.better-prompt-sentinel\"'",
            "statusMessage": "Cleaning up...",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
